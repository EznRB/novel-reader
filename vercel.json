{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/novel-reader/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/public" }
    },
    {
      "src": "artifacts/api-server/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/artifacts/api-server/src/index.ts" },
    { "src": "/(.*)", "dest": "/artifacts/novel-reader/$1" }
  ]
}
