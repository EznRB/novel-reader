# PostgreSQL connection string (required)
# For local dev: postgresql://user:password@localhost:5432/novellit
# For production: use Neon, Supabase, or Railway managed postgres
DATABASE_URL=postgresql://user:password@localhost:5432/novellit

# Session secret — generate a random string: openssl rand -hex 32
SESSION_SECRET=replace-with-a-random-64-char-hex-string

# OpenAI-compatible API (AI summaries, character extraction, Q&A)
# On Replit: use Replit AI Integrations (auto-configured)
# For self-hosting: set your OpenAI API key and base URL
AI_INTEGRATIONS_OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=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

# Node environment (set to "production" for deployments)
NODE_ENV=development

# Server port (set automatically by Replit/Railway/Render)
PORT=8080
